{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@/*": ["src/*"],
      "@gamekit/schema": ["../../packages/schema/src/index.ts"],
      "@gamekit/schema/*": ["../../packages/schema/src/*"],
      "@gamekit/runtime": ["../../packages/runtime/src/index.ts"],
      "@gamekit/runtime/*": ["../../packages/runtime/src/*"],
      "@gamekit/runtime-web": ["../../packages/runtime-web/src/index.ts"],
      "@gamekit/runtime-web/*": ["../../packages/runtime-web/src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
