                  "type": "setVariable",
                  "key": "sfxOn",
                  "value": true
                }
              ]
            },
            {
              "event": "cycleQuality",
              "actions": [
                {
                  "type": "setVariable",
                  "key": "quality",
                  "value": "high"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
