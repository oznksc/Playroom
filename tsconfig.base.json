{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@gamekit/schema": ["packages/schema/src/index.ts"],
      "@gamekit/runtime": ["packages/runtime/src/index.ts"],
      "@gamekit/runtime-web": ["packages/runtime-web/src/index.ts"],
      "@gamekit/agent": ["packages/agent/src/index.ts"]
    }
  }
}
