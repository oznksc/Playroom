{
  "name": "playroom-monorepo",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "description": "Playroom is an Expo-focused 2D game editor/runtime MVP.",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/oznksc/Playroom.git"
  },
  "bugs": {
    "url": "https://github.com/oznksc/Playroom/issues"
  },
  "homepage": "https://github.com/oznksc/Playroom#readme",
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build && pnpm --filter @gamekit/editor build",
    "typecheck": "pnpm --filter @gamekit/schema build && pnpm -r --filter './packages/**' --filter './apps/**' typecheck",
    "test": "pnpm --filter @gamekit/schema build && pnpm --filter @gamekit/runtime build && vitest run",
    "test:e2e": "pnpm --filter @gamekit/schema build && pnpm --filter @gamekit/runtime build && pnpm --filter @gamekit/cli build && pnpm --filter @gamekit/editor build && playwright test",
    "test:e2e:install": "playwright install chromium",
    "dev:editor": "pnpm --filter @gamekit/editor dev",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "gamekit": "pnpm --filter @gamekit/cli gamekit"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.8"
  }
}
