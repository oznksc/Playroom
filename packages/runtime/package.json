{
  "name": "@gamekit/runtime",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./collision": {
      "types": "./dist/collision.d.ts",
      "import": "./dist/collision.js"
    },
    "./camera": {
      "types": "./dist/camera.d.ts",
      "import": "./dist/camera.js"
    },
    "./player": {
      "types": "./dist/player.d.ts",
      "import": "./dist/player.js"
    },
    "./animate": {
      "types": "./dist/animate.d.ts",
      "import": "./dist/animate.js"
    },
    "./timeline": {
      "types": "./dist/timeline.d.ts",
      "import": "./dist/timeline.js"
    },
    "./scene": {
      "types": "./dist/scene.d.ts",
      "import": "./dist/scene.js"
    },
    "./manager": {
      "types": "./dist/manager.d.ts",
      "import": "./dist/manager.js"
    },
    "./rigid-body": {
      "types": "./dist/rigid-body.d.ts",
      "import": "./dist/rigid-body.js"
    },
    "./simulate": {
      "types": "./dist/simulate.d.ts",
      "import": "./dist/simulate.js"
    },
    "./input-map": {
      "types": "./dist/input-map.d.ts",
      "import": "./dist/input-map.js"
    },
    "./audio": {
      "types": "./dist/audio.d.ts",
      "import": "./dist/audio.js"
    },
    "./particles": {
      "types": "./dist/particles.d.ts",
      "import": "./dist/particles.js"
    },
    "./script": {
      "types": "./dist/script.d.ts",
      "import": "./dist/script.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@gamekit/schema": "workspace:*"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": ">=1.5.0",
    "react": ">=18.2.0",
    "react-native": ">=0.74.0",
    "react-native-gesture-handler": ">=2.16.0",
    "react-native-reanimated": ">=3.10.0",
    "react-native-safe-area-context": ">=4.0.0"
  },
  "devDependencies": {
    "@shopify/react-native-skia": "^1.5.4",
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "react-native": "^0.76.5",
    "react-native-safe-area-context": "^4.12.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
