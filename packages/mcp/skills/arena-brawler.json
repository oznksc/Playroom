{
  "name": "Arena Brawler",
  "description": "A compact combat arena with player and enemy state machines, health text, and collision-driven behavior hooks.",
  "orientation": "portrait",
  "viewport": { "width": 540, "height": 720, "background": "#1b1025" },
  "gravity": { "x": 0, "y": 1600 },
  "entities": [
    { "name": "Fighter", "components": [
      { "type": "Transform", "position": { "x": 150, "y": 580 }, "rotation": 0, "scale": { "x": 1, "y": 1 } },
      { "type": "Sprite", "assetId": "player", "width": 48, "height": 64, "anchor": { "x": 0.5, "y": 0.5 } },
      { "type": "AabbCollider", "offset": { "x": -24, "y": -32 }, "size": { "x": 48, "y": 64 }, "isStatic": false, "isTrigger": false },
      { "type": "PlayerController", "speed": 240, "jumpVelocity": 520, "gravity": 1600 },
      { "type": "StateMachine", "initialState": "idle", "states": [{ "name": "idle", "on": { "attack": "attacking" } }, { "name": "attacking", "on": { "finished": "idle" } }] },
      { "type": "Script", "handlers": [{ "event": "collisionEnter", "actions": [{ "type": "setVariable", "key": "lastHit", "value": true }] }] }
    ] },
    { "name": "Opponent", "components": [
      { "type": "Transform", "position": { "x": 390, "y": 580 }, "rotation": 0, "scale": { "x": 1, "y": 1 } },
      { "type": "Sprite", "assetId": "enemy", "width": 48, "height": 64, "anchor": { "x": 0.5, "y": 0.5 } },
      { "type": "AabbCollider", "offset": { "x": -24, "y": -32 }, "size": { "x": 48, "y": 64 }, "isStatic": false, "isTrigger": false },
      { "type": "RigidBody", "velocity": { "x": 0, "y": 0 }, "angularVelocity": 0, "mass": 1, "drag": 1, "isKinematic": false, "gravityScale": 1, "useGravity": true }
    ] },
    { "name": "ArenaFloor", "components": [
      { "type": "Transform", "position": { "x": 270, "y": 690 }, "rotation": 0, "scale": { "x": 1, "y": 1 } },
      { "type": "AabbCollider", "offset": { "x": -270, "y": -15 }, "size": { "x": 540, "y": 30 }, "isStatic": true, "isTrigger": false }
    ] }
  ]
}
