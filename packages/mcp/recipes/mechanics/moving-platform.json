{
  "id": "moving-platform",
  "name": "Moving Platform",
  "category": "mechanic",
  "description": "Static platform collider that follows a horizontal path.",
  "tags": ["platform", "path", "movement"],
  "targets": "entity",
  "merge": "upsert-by-type",
  "params": {
    "width": { "type": "number", "default": 150 },
    "height": { "type": "number", "default": 20 },
    "x1": { "type": "number", "default": 200 },
    "y1": { "type": "number", "default": 260 },
    "x2": { "type": "number", "default": 400 },
    "y2": { "type": "number", "default": 260 },
    "speed": { "type": "number", "default": 70 }
  },
  "components": [
    {
      "type": "AabbCollider",
      "offset": { "x": -75, "y": -10 },
      "size": { "x": "{{width}}", "y": "{{height}}" },
      "isStatic": true,
      "isTrigger": false,
      "layer": 1,
      "mask": 1
    },
    {
      "type": "FollowPath",
      "points": [
        { "x": "{{x1}}", "y": "{{y1}}" },
        { "x": "{{x2}}", "y": "{{y2}}" }
      ],
      "speed": "{{speed}}",
      "loop": true
    }
  ]
}
