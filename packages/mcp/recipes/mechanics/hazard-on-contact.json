{
  "id": "hazard-on-contact",
  "name": "Hazard on Contact",
  "category": "mechanic",
  "description": "Trigger hazard with entity tag + optional damage variable. Prefer hazard-kill-zone for rules-driven respawn/gameOver.",
  "tags": ["hazard", "damage", "spike", "enemy"],
  "targets": "entity",
  "merge": "upsert-by-type",
  "params": {
    "width": { "type": "number", "default": 32 },
    "height": { "type": "number", "default": 32 },
    "damageKey": { "type": "string", "default": "hit" },
    "damageValue": { "type": "number", "default": 1 }
  },
  "entityTags": ["hazard"],
  "components": [
    {
      "type": "AabbCollider",
      "offset": { "x": -16, "y": -16 },
      "size": { "x": "{{width}}", "y": "{{height}}" },
      "isStatic": true,
      "isTrigger": true,
      "layer": 1,
      "mask": 1
    },
    {
      "type": "Script",
      "handlers": [
        {
          "event": "onTriggerEnter",
          "actions": [
            { "type": "setVariable", "key": "{{damageKey}}", "value": "{{damageValue}}" }
          ]
        }
      ]
    }
  ],
  "notes": "Tag alone enables auto tagContact when no explicit hazard is configured. Use hazard-kill-zone for explicit onTrigger."
}
