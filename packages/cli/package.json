{
  "name": "@gamekit/cli",
  "version": "0.1.1",
  "type": "module",
  "bin": {
    "gamekit": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "gamekit": "tsx src/index.ts"
  },
  "dependencies": {
    "@gamekit/agent": "workspace:*",
    "@gamekit/mcp": "workspace:*",
    "@gamekit/schema": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@gamekit/runtime": "workspace:*",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
